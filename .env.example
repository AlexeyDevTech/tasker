# Скопируйте в .env и заполните значениями.

# --- База данных (Prisma / SQLite) ---
DATABASE_URL="file:./dev.db"

# --- NextAuth ---
# Сгенерировать: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# --- OAuth-провайдеры (необязательно) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# --- GitHub-интеграция (Фаза 5) ---
# Секрет вебхука GitHub. Если задан — входящие вебхуки проверяются по подписи
# X-Hub-Signature-256; если пуст — подпись НЕ проверяется (только для разработки).
GITHUB_WEBHOOK_SECRET=""

# --- Сид (необязательно) ---
SEED_ADMIN_EMAIL="admin@tasker.local"
SEED_ADMIN_PASSWORD="admin123"
SEED_ADMIN_NAME="Admin"
