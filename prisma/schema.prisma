// TaskFlow - Full Project Management Schema
// Adapted for SQLite with relations

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  image         String?
  password      String?  // For email/password auth
  emailVerified DateTime?
  
  // Preferences
  preferredTheme     String  @default("system")
  preferredWorkTime  String  @default("morning") // morning, afternoon, evening
  timezone           String  @default("UTC")
  
  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  accounts      Account[]
  sessions      Session[]
  ownedProjects Project[]          @relation("OwnedProjects")
  assignedTasks Task[]             @relation("AssignedTasks")
  comments      Comment[]
  notifications Notification[]
  projectMembers ProjectMember[]
  activities    Activity[]
  tags          Tag[]
  
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  
  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================
// PROJECTS
// ============================================

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#6366f1")
  icon        String?  // Emoji or icon name
  
  // Hierarchy
  parentId    String?
  parent      Project?        @relation("ProjectHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    Project[]       @relation("ProjectHierarchy")
  
  // Dates
  startDate   DateTime?
  endDate     DateTime?
  
  // Status
  status      String   @default("active") // active, completed, archived, on-hold
  progress    Int      @default(0) // 0-100
  
  // Template reference
  templateId      String?
  isTemplate      Boolean  @default(false)
  templateCategory String?
  
  // Owner
  ownerId     String
  owner       User     @relation("OwnedProjects", fields: [ownerId], references: [id], onDelete: Cascade)
  
  // Settings (JSON)
  settings    String?  // JSON string for project-specific settings
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  tasks           Task[]
  members         ProjectMember[]
  milestones      Milestone[]
  activities      Activity[]
  
  @@index([ownerId])
  @@index([parentId])
  @@map("projects")
}

// ============================================
// PROJECT MEMBERS & PERMISSIONS
// ============================================

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String   @default("editor") // owner, editor, commenter, viewer
  
  joinedAt  DateTime @default(now())
  
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([projectId, userId])
  @@map("project_members")
}

// ============================================
// TEMPLATES
// ============================================

model Template {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String   // software, marketing, content, design, etc.
  icon        String?
  color       String   @default("#6366f1")
  
  // Structure (JSON)
  structure   String   // JSON with tasks, dependencies, milestones
  
  // Metadata
  isPublic    Boolean  @default(false)
  usageCount  Int      @default(0)
  
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("templates")
}

// ============================================
// TASKS
// ============================================

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  
  // Project
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Hierarchy (subtasks)
  parentId    String?
  parent      Task?            @relation("TaskHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks    Task[]           @relation("TaskHierarchy")
  
  // Assignment
  assigneeId  String?
  assignee    User?            @relation("AssignedTasks", fields: [assigneeId], references: [id], onDelete: SetNull)
  
  // Status & Priority
  status      String   @default("todo") // todo, in-progress, review, done, cancelled
  priority    String   @default("medium") // urgent, high, medium, low
  
  // Dates
  startDate   DateTime?
  dueDate     DateTime?
  completedAt DateTime?
  estimatedHours Float?
  actualHours    Float?
  
  // Position for ordering
  position    Int      @default(0)
  
  // Progress (for tasks with subtasks)
  progress    Int      @default(0) // 0-100
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  dependenciesFrom Dependency[] @relation("TaskDependsOn")
  dependenciesTo   Dependency[] @relation("TaskDependent")
  comments      Comment[]
  tags          TaskTag[]
  attachments   Attachment[]
  checklist     ChecklistItem[]
  milestone     Milestone?      @relation(fields: [milestoneId], references: [id])
  milestoneId   String?
  
  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
  @@index([parentId])
  @@map("tasks")
}

// ============================================
// DEPENDENCIES
// ============================================

model Dependency {
  id             String   @id @default(cuid())
  
  // Tasks
  taskId         String   // The task that depends on another
  dependsOnId    String   // The task being depended on
  
  task           Task     @relation("TaskDependsOn", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn      Task     @relation("TaskDependent", fields: [dependsOnId], references: [id], onDelete: Cascade)
  
  // Type: finish-to-start, start-to-start, finish-to-finish, start-to-finish
  type           String   @default("finish-to-start")
  
  // Lag time in days
  lagDays        Int      @default(0)
  
  createdAt      DateTime @default(now())
  
  @@unique([taskId, dependsOnId])
  @@map("dependencies")
}

// ============================================
// MILESTONES
// ============================================

model Milestone {
  id          String   @id @default(cuid())
  title       String
  description String?
  
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  date        DateTime
  color       String   @default("#f59e0b")
  isCompleted Boolean  @default(false)
  
  tasks       Task[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([projectId])
  @@map("milestones")
}

// ============================================
// COMMENTS
// ============================================

model Comment {
  id        String   @id @default(cuid())
  content   String
  
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  // For threading
  parentId  String?
  parent    Comment? @relation("CommentThread", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentThread")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([taskId])
  @@map("comments")
}

// ============================================
// TAGS
// ============================================

model Tag {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6366f1")
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  tasks     TaskTag[]
  
  @@unique([userId, name])
  @@map("tags")
}

model TaskTag {
  taskId    String
  tagId     String
  
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  @@unique([taskId, tagId])
  @@map("task_tags")
}

// ============================================
// ATTACHMENTS
// ============================================

model Attachment {
  id          String   @id @default(cuid())
  name        String
  url         String
  type        String   // image, document, video, etc.
  size        Int?     // in bytes
  
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  uploadedBy  String?
  createdAt   DateTime @default(now())
  
  @@map("attachments")
}

// ============================================
// CHECKLIST ITEMS
// ============================================

model ChecklistItem {
  id        String   @id @default(cuid())
  title     String
  isDone    Boolean  @default(false)
  position  Int      @default(0)
  
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("checklist_items")
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id          String   @id @default(cuid())
  type        String   // task-assigned, comment, mention, deadline, etc.
  title       String
  message     String
  data        String?  // JSON with additional data
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  isRead      Boolean  @default(false)
  readAt      DateTime?
  
  createdAt   DateTime @default(now())
  
  @@index([userId, isRead])
  @@map("notifications")
}

// ============================================
// ACTIVITY LOG
// ============================================

model Activity {
  id          String   @id @default(cuid())
  type        String   // created, updated, completed, commented, etc.
  description String
  data        String?  // JSON with details
  
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  @@index([projectId])
  @@index([userId])
  @@map("activities")
}
